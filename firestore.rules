rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
        (request.auth.token.email == "aguspuryanto@gmail.com" && request.auth.token.email_verified == true));
    }

    // Allow read/write for authenticated users for now (prototype rules)
    // In a real app, you would restrict this based on roles and ownership.
    
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() && request.auth.uid == userId;
    }

    match /items/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Admins or authorized users in production
    }

    match /purchase_orders/{poId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /sales_orders/{soId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /finance_transactions/{txId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
  }
}
